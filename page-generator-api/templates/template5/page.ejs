<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <style>
    :root {
      --mint-1: #f1fbf4;
      --mint-2: #e2f3e8;
      --mint-3: #d0e8d8;
      --teal: #2e6871;
      --teal-deep: #275860;
      --orange: #ff8f4e;
      --red: #fb374e;
      --card: rgba(255, 255, 255, 0.96);
      --text: #202020;
      --link: #2d5fd3;
      --shadow: 0 14px 36px rgba(64, 91, 77, 0.14);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, var(--mint-1) 0%, #ffffff 100%);
    }

    .page {
      width: 100%;
      margin: 0 auto;
      min-height: 100vh;
      position: relative;
      overflow: hidden;
      padding-bottom: 6vh;
    }

    .hero {
      position: relative;
      padding: 2.4vw 2.4vw 0;
    }

    .hero-image {
      position: relative;
      z-index: 1;
      margin-top: 1.2vh;
      border-radius: 6vw 6vw 0 0;
      overflow: hidden;
      box-shadow: 0 1.3vh 3.5vh rgba(52, 89, 70, 0.08);
      background: #fff;
    }

    .hero-image img {
      display: block;
      width: 100%;
      height: auto;
    }

    .card {
      margin: 2.4vh 3.2vw 0;
      background: var(--card);
      border-radius: 7vw;
      box-shadow: var(--shadow);
      padding: 3.2vh 3.6vw;
    }

    .claim-title {
      text-align: center;
      font-size: 6.8vw;
      margin: 0 0 2.8vh;
      font-weight: 800;
      line-height: 1.35;
    }

    .claim-title span {
      color: #f26156;
    }

    .input-shell {
      display: flex;
      align-items: center;
      background: linear-gradient(180deg, #fff8ef, #fff6ea);
      border: 1px solid rgba(236, 193, 117, 0.7);
      border-radius: 6vw;
      padding: 0 2.4vw;
      height: 10vh;
      overflow: hidden;
    }

    .input-label {
      font-size: 5vw;
      font-weight: 700;
      color: #111;
      padding: 0 2.4vw 0 2.8vw;
      white-space: nowrap;
    }

    .input-shell input {
      border: 0;
      outline: 0;
      background: transparent;
      flex: 1;
      font-size: 4.3vw;
      color: #4a4a4a;
      min-width: 0;
    }

    .cta {
      width: 100%;
      border: 0;
      margin-top: 3.2vh;
      border-radius: 999px;
      color: #fff;
      font-size: 7vw;
      font-weight: 800;
      letter-spacing: 1px;
      height: 10.5vh;
      background: linear-gradient(90deg, var(--orange), var(--red));
      box-shadow: 0 1.8vh 3.6vh rgba(255, 100, 90, 0.28);
      position: relative;
    }

    .cta::after {
      content: "☞";
      position: absolute;
      right: 6vw;
      bottom: 0;
      font-size: 12vw;
      transform: rotate(-16deg);
      filter: drop-shadow(0 1vh 1.2vh rgba(69, 98, 150, 0.18));
    }

    .agreement {
      margin-top: 2vh;
      display: flex;
      align-items: flex-start;
      gap: 2vw;
      text-align: left;
      color: #3a3a3a;
      font-size: 3.8vw;
      line-height: 1.8;
    }

    .agreement input {
      appearance: none;
      -webkit-appearance: none;
      width: 4.6vw;
      height: 4.6vw;
      margin-top: 0.5vh;
      flex: 0 0 auto;
      border: 1px solid #5a78d6;
      border-radius: 50%;
      background: #fff;
      position: relative;
      cursor: pointer;
    }

    .agreement input:checked {
      background: #4d6fe0;
      border-color: #4d6fe0;
    }

    .agreement input:checked::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      width: 1.3vw;
      height: 0.7vw;
      border-left: 0.35vw solid #fff;
      border-bottom: 0.35vw solid #fff;
      transform: translate(-50%, -60%) rotate(-45deg);
    }

    .agreement a {
      color: var(--link);
      text-decoration: none;
      font-weight: 700;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 3vh;
      transform: translateX(-50%) translateY(20px);
      background: rgba(22, 22, 22, 0.84);
      color: #fff;
      padding: 1.3vh 2.4vw;
      border-radius: 999px;
      font-size: 3.6vw;
      opacity: 0;
      pointer-events: none;
      transition: 0.25s ease;
      z-index: 40;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(24, 28, 28, 0.48);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 3vh 3.2vw;
      z-index: 50;
    }

    .modal.show {
      display: flex;
    }

    .modal-panel {
      width: 92vw;
      max-height: 82vh;
      background: #fff;
      border-radius: 6vw;
      box-shadow: 0 3vh 6vh rgba(0, 0, 0, 0.18);
      overflow: hidden;
    }

    .modal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2vh 3.2vw;
      border-bottom: 1px solid #edf0ee;
    }

    .modal-head h2 {
      margin: 0;
      font-size: 5vw;
      color: var(--teal-deep);
    }

    .modal-close {
      width: 8vw;
      height: 8vw;
      border-radius: 50%;
      border: 0;
      background: #edf3ee;
      color: #44634a;
      font-size: 4.5vw;
    }

    .modal-body {
      padding: 2vh 3.2vw 2.4vh;
      overflow: auto;
      max-height: calc(82vh - 10vh);
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 3.6vw;
      line-height: 1.8;
      color: #415245;
      background: linear-gradient(180deg, #ffffff, #f9fbf9);
    }

    .modal-body.loading {
      color: #7c8d7f;
    }

    @media (max-width: 560px) {
      .hero,
      .card {
        margin-left: 2vw;
        margin-right: 2vw;
        width: auto;
      }

      .hero {
        padding-left: 0;
        padding-right: 0;
      }

      .hero-image {
        border-radius: 4.5vw 4.5vw 0 0;
      }

      .input-shell {
        height: 7vh;
      }

      .input-label {
        font-size: 4.8vw;
        padding-left: 2vw;
        padding-right: 2vw;
      }

      .cta {
        height: 7vh;
      }

      .cta::after {
        right: 4vw;
        font-size: 10vw;
      }
    }
  </style>
</head>
<body>
  <audio id="bgAudio" src="<%= bg_audio %>" autoplay preload="auto" playsinline webkit-playsinline x5-playsinline></audio>

  <div class="page">
    <section class="hero">
      <div class="hero-image">
        <img src="<%= main_image %>" alt="主图">
      </div>
    </section>

    <section class="card">
      <h2 class="claim-title"><span>立即领取</span> 专属体验名额</h2>
      <label class="input-shell">
        <span class="input-label">手机号码</span>
        <input id="phone" type="tel" maxlength="11" inputmode="numeric" placeholder="您的信息将被严格保密">
      </label>
      <button class="cta" id="claimBtn" type="button"><%= button_text %></button>
      <div class="agreement">
        <input id="agreePolicy" type="checkbox">
        <label for="agreePolicy">
          点击领取即表示您已阅读并同意
          <a href="javascript:void(0)" id="openPolicyInline">《隐私协议》</a>
        </label>
      </div>
    </section>
  </div>

  <div class="toast" id="toast"></div>

  <div class="modal" id="policyModal" aria-hidden="true">
    <div class="modal-panel">
      <div class="modal-head">
        <h2>隐私协议</h2>
        <button class="modal-close" id="closeModal" type="button">×</button>
      </div>
      <div class="modal-body loading" id="policyContent">协议加载中...</div>
    </div>
  </div>

  <script>
    const phoneInput = document.getElementById("phone");
    const agreePolicy = document.getElementById("agreePolicy");
    const claimBtn = document.getElementById("claimBtn");
    const toast = document.getElementById("toast");
    const audio = document.getElementById("bgAudio");
    const policyModal = document.getElementById("policyModal");
    const policyContent = document.getElementById("policyContent");
    const closeModal = document.getElementById("closeModal");
    const openPolicyInline = document.getElementById("openPolicyInline");

    let policyLoaded = false;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => {
        toast.classList.remove("show");
      }, 2200);
    }

    function validPhone(value) {
      return /^1\\d{10}$/.test(value);
    }

    let audioActivated = false;

    async function ensureAudioPlayback() {
      try {
        if (audioActivated && !audio.paused) return;
        audio.muted = false;
        await audio.play();
        audioActivated = true;
      } catch (error) {
        // Mobile browsers may require a user gesture first.
      }
    }

    function bindAudioAutoPlay() {
      const retryPlay = () => {
        ensureAudioPlayback();
      };

      document.addEventListener("DOMContentLoaded", retryPlay);
      window.addEventListener("load", retryPlay);
      window.addEventListener("pageshow", retryPlay);
      document.addEventListener("WeixinJSBridgeReady", retryPlay, false);
      document.addEventListener("YixinJSBridgeReady", retryPlay, false);
      document.addEventListener("readystatechange", () => {
        if (document.readyState === "complete") {
          retryPlay();
        }
      });
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") {
          retryPlay();
        }
      });
      audio.addEventListener("canplay", retryPlay);
      document.addEventListener("click", retryPlay, { once: true });
      document.addEventListener("touchstart", retryPlay, { once: true });
    }

    async function loadPolicy() {
      if (policyLoaded) return;
      try {
        const response = await fetch("./static/user_licence.txt", { cache: "no-store" });
        const text = await response.text();
        policyContent.textContent = text || "暂无协议内容";
        policyContent.classList.remove("loading");
        policyLoaded = true;
      } catch (error) {
        policyContent.textContent = "协议加载失败，请稍后重试。";
        policyContent.classList.remove("loading");
      }
    }

    async function openPolicy() {
      policyModal.classList.add("show");
      policyModal.setAttribute("aria-hidden", "false");
      await loadPolicy();
      ensureAudioPlayback();
    }

    function closePolicy() {
      policyModal.classList.remove("show");
      policyModal.setAttribute("aria-hidden", "true");
    }

    claimBtn.addEventListener("click", async () => {
      const value = phoneInput.value.trim();
      await ensureAudioPlayback();
      if (!agreePolicy.checked) {
        showToast("请先勾选隐私协议");
        return;
      }
      if (!validPhone(value)) {
        showToast("请输入正确的11位手机号");
        return;
      }
      showToast("领取成功，稍后会有专人与您联系");
    });

    openPolicyInline.addEventListener("click", openPolicy);
    closeModal.addEventListener("click", closePolicy);

    policyModal.addEventListener("click", (event) => {
      if (event.target === policyModal) {
        closePolicy();
      }
    });

    phoneInput.addEventListener("input", () => {
      phoneInput.value = phoneInput.value.replace(/\\D/g, "").slice(0, 11);
    });

    bindAudioAutoPlay();
    ensureAudioPlayback();
  </script>
</body>
</html>
