{
  "code": "template1",
  "name": "长图底部跳转模板",
  "description": "主图列表 + 底部固定跳转图",
  "engine": "ejs",
  "output": {
    "htmlFile": "index.html",
    "staticDir": "static"
  },
  "fixedFields": [
    {
      "key": "title",
      "label": "页面标题",
      "type": "input",
      "required": true
    },
    {
      "key": "folderName",
      "label": "文件夹名",
      "type": "input",
      "required": true
    }
  ],
  "dynamicFields": [
    {
      "key": "main_images",
      "label": "主图数组",
      "type": "array",
      "required": true,
      "itemFields": [
        {
          "key": "value",
          "label": "图片地址",
          "type": "image",
          "required": true
        }
      ]
    },
    {
      "key": "target_image",
      "label": "底部跳转图片",
      "type": "image",
      "required": true
    }
  ]
}