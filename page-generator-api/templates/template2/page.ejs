<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
</head>
<style>
    body {margin: 0;padding: 0;}
    #app {width: 100%;height: 100vh;display: flex;flex-direction: column;}
    #main {width: 100%;height: 89vh;overflow-y: auto;display: flex;flex-direction: column;}
    .image {max-width: 100%;height: auto;}
    #target {width: 100%;height: 10vh;position: fixed;bottom: 0;z-index: 999;}
    #order-box {position: fixed;top: 10px;left: 10px;z-index: 1000;min-width: 50vw; /* 最大半屏 */max-width: 70vw;pointer-events: none;}
    #order-list {list-style: none;margin: 0;padding: 0;}
    #order-list li {background: rgba(0, 0, 0, 0.4); color: #fff;font-size: 11px;line-height: 1.4;padding: 6px 10px;border-radius: 12px;margin-bottom: 6px;word-break: break-all; opacity: 0;transform: translateY(10px);transition: all 0.5s ease;}
    #order-list li.show {opacity: 1;transform: translateY(0);}
    #order-list li.hide {opacity: 0;transform: translateY(-10px);}
</style>
<body>
<!-- 左上角下单滚动列表 -->
<div id="order-box">
    <ul id="order-list"></ul>
</div>
<div id="app">
    <div id="main">
       <% main_images.forEach(img => { %>
            <img src="<%= img %>" class="image" alt="图片">
        <% }) %>
    </div>
    <img src="<%= target_image %>" id="target" alt="跳转图片">
</div>
</body>
<script>
    // 从URL获取中获取跳转参数path
    let urlObj = new URL(location.href);
    const path = urlObj.searchParams.get('path');
    const title = urlObj.searchParams.get('title');
    if (title) {
        document.title = title
    }
    if (path) {
        document.querySelector("#target").onclick = () => {
            window.location.href = path
        }
    }

    const defaultProducts = "<%= product %>"
    const surnames = ['张', '李', '王', '赵', '刘', '陈', '杨', '黄', '吴', '周'];
    let products = [];
    if (defaultProducts) {
        products = defaultProducts.split(',')
    } else {
       products = ['五粮液酒具', '五粮液酒', '扫地机器人', '贵州茅台酒']
    }

    const MAX_COUNT = 5;
    const listEl = document.getElementById('order-list');

    function randomItem(arr) {
        return arr[Math.floor(Math.random() * arr.length)];
    }

    function randomMinutes() {
        return Math.floor(Math.random() * 9) + 1;
    }

    function createText() {
        return `${randomItem(surnames)}** 在${randomMinutes()}分钟前下单了产品${randomItem(products)}`;
    }

    function createItem() {
        const li = document.createElement('li');
        li.innerText = createText();
        return li;
    }

    // 初始化 5 条
    for (let i = 0; i < MAX_COUNT; i++) {
        const li = createItem();
        listEl.appendChild(li);
        setTimeout(() => li.classList.add('show'), i * 200);
    }

    // 每次滚动：移除一条，新增一条
    setInterval(() => {
        const first = listEl.firstElementChild;
        if (!first) return;

        // 先隐藏第一条
        first.classList.remove('show');
        first.classList.add('hide');

        // 动画结束后移除并补一条
        setTimeout(() => {
            listEl.removeChild(first);

            const newItem = createItem();
            listEl.appendChild(newItem);

            // 强制重绘，确保动画生效
            requestAnimationFrame(() => {
                newItem.classList.add('show');
            });
        }, 500);
    }, 3000);
</script>
</html>