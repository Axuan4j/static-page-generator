<!DOCTYPE html>
<html lang="en" style="font-size: 57px">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
</head>
<style>
    body {
        margin: 0;
        padding: 0;
    }

    #app {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

    #main {
        width: 100%;
        height: 90vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .image {
        max-width: 100%;
        height: auto;
    }

    #order-list li {
        background: rgba(0, 0, 0, 0.4);
        color: #fff;
        font-size: 11px;
        line-height: 1.4;
        padding: 6px 10px;
        border-radius: 12px;
        margin-bottom: 6px;
        word-break: break-all;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.5s ease;
    }

    #order-list li.show {
        opacity: 1;
        transform: translateY(0);
    }

    #order-list li.hide {
        opacity: 0;
        transform: translateY(-10px);
    }

    @keyframes scaleAnimation {
        0% {
            transform: scale(0.8);
        }
        100% {
            transform: scale(1);
        }
    }

    .submit_btn {
        position: fixed;
        left: 0;
        bottom: 0;
        z-index: 1;
        width: 100%;
        background-color: #ffffff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-top: 0.2rem;
        padding-bottom: 0.4rem;
    }

    .submit_btn .href {
        width: 80%;
        height: 1rem;
        background: linear-gradient(to right, #fb5705, #ffb21e);
        animation: scaleAnimation 0.3s alternate infinite;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 1rem;
    }

    .submit_btn .href .top {
        color: #ffffff;
        font-size: 0.38rem;
        display: flex;
        align-items: center;
    }

    .submit_btn .href .top .img {
        width: 0.45rem;
        height: 0.45rem;
    }

    .submit_btn .href .top .text {
        padding-left: 0.1rem;
    }
</style>
<body>
<div id="app">
    <div id="main">
         <% main_images.forEach(img => { %>
            <img src="<%= img %>" class="image" alt="图片">
        <% }) %>
    </div>
    <div class="submit_btn">
        <div class="href">
            <div class="top">
                <span class="text"><%= button_text %></span>
            </div>
        </div>
    </div>
</div>
</body>
<script>
    // 从URL获取中获取跳转参数path
    let urlObj = new URL(location.href);
    const path = urlObj.searchParams.get('path');
    const title = urlObj.searchParams.get('title');
    if (title) {
        document.title = title
    }
    if (path) {
        document.querySelector("#target").onclick = () => {
            window.location.href = path
        }
    }
</script>
</html>